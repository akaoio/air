#!/bin/bash
# Bun wrapper script for Air project

# Add Bun to PATH
export PATH="$HOME/.bun/bin:$PATH"

# If bun command is available, use it directly
if command -v bun &> /dev/null; then
    # Check if we're in the Air directory and running status/config/etc
    if [[ "$1" == "status" ]] || [[ "$1" == "config" ]] || [[ "$1" == "ddns" ]]; then
        # Run npm script which handles fallbacks properly
        npm run "$@"
    else
        # Run bun directly
        ~/.bun/bin/bun "$@"
    fi
else
    echo "Error: Bun not found at ~/.bun/bin/bun"
    exit 1
fi