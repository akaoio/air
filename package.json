{
    "name": "@akaoio/air",
    "type": "module",
    "version": "2.0.0",
    "description": "Distributed graph database - TypeScript/Bun edition",
    "main": "dist/index.cjs",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "engines": {
        "bun": ">=1.0.0",
        "node": ">=18.0.0"
    },
    "license": "MIT",
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "bin": {
        "air-install": "./script/run.cjs install"
    },
    "dependencies": {
        "@akaoio/gun": "^0.2020.1240",
        "node-fetch": "^3.3.2"
    },
    "scripts": {
        "start": "bun run src/main.ts || tsx src/main.ts",
        "start:node": "tsx src/main.ts",
        "start:bun": "bun run src/main.ts",
        "dev": "bun --hot src/main.ts",
        "build": "akao-build",
        "build:watch": "akao-build --watch",
        "build:prod": "akao-build --clean && cp src/paths.js dist/paths.js",
        "pretest": "[ -f dist/paths.js ] || cp src/paths.js dist/paths.js",
        "test": "npm run build && tsx test/battle/index.ts",
        "test:watch": "akao-build --watch",
        "test:scripts": "tsx test/battle/scripts.battle.ts",
        "test:interactive": "tsx test/battle/interactive.battle.ts",
        "test:bun": "tsx test/battle/bun-runtime.battle.ts",
        "test:all": "npm run test",
        "typecheck": "tsc --noEmit",
        "format": "bunx prettier --write . || npx prettier --write .",
        "docs:build": "npx @akaoio/composer build --config composer.config.cjs",
        "docs:watch": "npx @akaoio/composer watch --config composer.config.cjs",
        "install": "node script/run.cjs install",
        "config": "node script/run.cjs install",
        "ddns": "node script/run.cjs ddns",
        "status": "node script/run.cjs status",
        "logs": "node script/run.cjs logs",
        "update": "node script/update.cjs",
        "uninstall": "node script/uninstall.cjs"
    },
    "devDependencies": {
        "@akaoio/battle": "*",
        "@akaoio/builder": "*",
        "@akaoio/composer": "*",
        "@types/bun": "^1.2.20",
        "@types/node": "^20.19.11",
        "bun-types": "^1.2.20",
        "node-pty": "^1.0.0",
        "prettier": "^3.0.0",
        "tsx": "^4.20.4",
        "typescript": "^5.9.2"
    }
}
