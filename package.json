{
    "name": "@akaoio/air",
    "type": "module",
    "version": "2.0.0",
    "description": "Distributed graph database - TypeScript/Bun edition",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "engines": {
        "bun": ">=1.0.0",
        "node": ">=18.0.0"
    },
    "license": "MIT",
    "bin": {
        "air-install": "./script/install.js"
    },
    "dependencies": {
        "@akaoio/gun": "^0.2020.1240",
        "@akaoio/tui": "^1.0.4",
        "node-fetch": "^3.3.2"
    },
    "scripts": {
        "start": "bun run src/main.ts || tsx src/main.ts",
        "start:node": "tsx src/main.ts",
        "start:bun": "bun run src/main.ts",
        "dev": "bun --hot src/main.ts",
        "build": "tsx build.ts",
        "build:node": "tsc -p tsconfig.build.json",
        "build:bun": "bun build src/index.ts --outdir dist --target bun",
        "build:prod": "tsx build.ts",
        "test": "tsx test/universal.test.ts",
        "test:bun": "bun test/universal.test.ts",
        "test:node": "tsx test/universal.test.ts",
        "test:all": "npm run test",
        "typecheck": "tsc --noEmit",
        "format": "bunx prettier --write . || npx prettier --write .",
        "install": "bun script/install.ts || tsx script/install.ts",
        "config": "bun script/config.ts || tsx script/config.ts",
        "ddns": "bun script/ddns.ts || tsx script/ddns.ts",
        "status": "bun script/status.ts || tsx script/status.ts",
        "logs": "bun script/logs.ts || tsx script/logs.ts",
        "update": "bun script/update.ts || tsx script/update.ts",
        "uninstall": "bun script/uninstall.ts || tsx script/uninstall.ts"
    },
    "devDependencies": {
        "@types/bun": "^1.2.20",
        "@types/node": "^20.19.11",
        "bun-types": "^1.2.20",
        "prettier": "^3.0.0",
        "tsx": "^4.20.4",
        "typescript": "^5.9.2",
        "vitest": "^1.6.1"
    }
}
