{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        // Production build settings
        "target": "ES2020",
        "module": "ES2020",
        "lib": ["ES2020"],

        // Output settings
        "outDir": "./dist",
        "rootDir": "./src",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,

        // Module resolution for production
        "moduleResolution": "node",
        "allowImportingTsExtensions": false,
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,

        // Emit output
        "noEmit": false,
        "removeComments": true,

        // Production mode - focus on working code
        "strict": false,
        "skipLibCheck": true,
        "noImplicitAny": false,
        "forceConsistentCasingInFileNames": true
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules", "dist", "test", "tmp", "script"]
}
